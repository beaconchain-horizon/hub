    <div class="products-grid" id="productsContainer"></div>
    <div class="wallet-box">
      <span>📡 Wallet (ETH / USDC / BNB):</span><br>
      <code>0x4E94F10F0a34a0DF229e68d5902644046258D678</code>
    </div>
    <button id="generateLicenseBtn" class="buy-btn" style="width: auto;"><i class="fas fa-file-certificate"></i> Generate .license (simulate purchase)</button>
