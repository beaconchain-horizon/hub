  <!-- ========== SECTION 3: OFFLINE FILE VERIFICATION ========== -->
  <div class="glass-card">
    <h2><i class="fas fa-fingerprint"></i> Offline verification – SHA‑256 integrity</h2>
    <p>Upload any file (APK, binary, zip). The library computes its hash – compare with catalog to verify authenticity.</p>
    <input type="file" id="fileInput" style="background:#1e293b; border:1px solid #4f9eff; padding:0.5rem; border-radius:1rem; width:100%;">
    <button id="verifyFileBtn" class="demo-btn" style="margin-top:0.5rem;">🔍 Compute SHA‑256</button>
